      "claim_type": "visible_text",
      "mode": "visible_text_cue",
      "text_scope": "combined"
    },
    {
      "claim_type": "background_color",
      "mode": "color_noun",
      "colors_key": "background_colors",
      "noun_regex": "background|backdrop|wall",
      "text_scope": "normalized_then_combined"
    },
    {
      "claim_type": "style_medium",
      "mode": "hints",
      "profile_key": "style_words",
      "match": "contains",
      "text_scope": "normalized_then_combined"
    },
    {
      "claim_type": "composition",
