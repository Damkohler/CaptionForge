{
  "profile_name": "general_v1",
  "profile_version": "1.0.0",
  "description": "General-purpose CaptionForge semantic profile for broad image captions with minimal domain assumptions.",
  "claim_types": [
    "subject",
    "attribute",
    "action",
    "style_medium",
    "composition",
    "background_color",
    "background_object",
    "object_prop",
    "visible_text",
    "general"
